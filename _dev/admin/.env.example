# Copy to .env and fill in. Never commit the real .env file.
ADMIN_TOKEN=change-me-to-a-long-random-string
# Optional — without it, a random key is generated per container start,
# so a restart logs everyone out. Set it to survive restarts.
ADMIN_SECRET_KEY=
# Numeric UID that owns this repo's working tree on this host — run
# `stat -c %u .` from the repo root to find it. Must match for
# Save/Publish to have write access to the mounted repo.
APP_UID=1000
